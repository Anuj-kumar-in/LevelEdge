    "lucide-react": "^1.16.0",
    "mongoose": "^8.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.1",
    "react-window": "^2.2.7",
